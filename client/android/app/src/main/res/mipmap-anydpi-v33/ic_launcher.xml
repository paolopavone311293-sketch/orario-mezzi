<svg viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background circle -->
  <circle cx="96" cy="96" r="96" fill="url(#bgGradient)"/>

  <!-- Calendar part (top half) -->
  <g transform="translate(35, 25)">
    <!-- Calendar frame -->
    <rect x="0" y="0" width="122" height="70" rx="8" fill="white" opacity="0.95"/>

    <!-- Calendar header -->
    <rect x="0" y="0" width="122" height="18" rx="8" fill="#3b82f6"/>

    <!-- Calendar dots/holes -->
    <circle cx="12" cy="9" r="2.5" fill="white"/>
    <circle cx="110" cy="9" r="2.5" fill="white"/>

    <!-- Calendar grid lines -->
    <line x1="0" y1="18" x2="122" y2="18" stroke="#e5e7eb" stroke-width="1"/>

    <!-- Day labels -->
    <text x="8" y="32" font-size="8" fill="#6b7280" font-weight="bold">L</text>
    <text x="28" y="32" font-size="8" fill="#6b7280" font-weight="bold">M</text>
    <text x="48" y="32" font-size="8" fill="#6b7280" font-weight="bold">M</text>
    <text x="68" y="32" font-size="8" fill="#6b7280" font-weight="bold">G</text>
    <text x="88" y="32" font-size="8" fill="#6b7280" font-weight="bold">V</text>
    <text x="105" y="32" font-size="8" fill="#6b7280" font-weight="bold">S</text>

    <!-- Calendar dates -->
    <circle cx="12" cy="50" r="5" fill="#10b981" opacity="0.2"/>
    <text x="10" y="53" font-size="10" fill="#10b981" font-weight="bold">1</text>

    <circle cx="32" cy="50" r="5" fill="#10b981"/>
    <text x="29" y="53" font-size="10" fill="white" font-weight="bold">2</text>

    <circle cx="52" cy="50" r="5" fill="#10b981"/>
    <text x="49" y="53" font-size="10" fill="white" font-weight="bold">3</text>
  </g>

  <!-- Car part (bottom half) -->
  <g transform="translate(30, 110)">
    <!-- Car body -->
    <rect x="0" y="25" width="132" height="35" rx="6" fill="white" opacity="0.95"/>

    <!-- Car top -->
    <rect x="25" y="10" width="82" height="20" rx="4" fill="white" opacity="0.95"/>

    <!-- Windshield -->
    <polygon points="30,15 50,10 90,10 110,15" fill="#93c5fd" opacity="0.6"/>

    <!-- Left wheel -->
    <circle cx="22" cy="65" r="12" fill="#374151"/>
    <circle cx="22" cy="65" r="8" fill="#9ca3af"/>
    <circle cx="22" cy="65" r="4" fill="#1f2937"/>

    <!-- Right wheel -->
    <circle cx="110" cy="65" r="12" fill="#374151"/>
    <circle cx="110" cy="65" r="8" fill="#9ca3af"/>
    <circle cx="110" cy="65" r="4" fill="#1f2937"/>

    <!-- Headlights -->
    <circle cx="8" cy="35" r="4" fill="#fbbf24"/>
    <circle cx="8" cy="45" r="4" fill="#fbbf24"/>

    <!-- Door -->
    <rect x="50" y="28" width="35" height="32" rx="2" fill="none" stroke="#d1d5db" stroke-width="1.5"/>
  </g>
</svg>